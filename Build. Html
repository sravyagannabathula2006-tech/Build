<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>My Portfolio</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 0;
            background: #f4f4f4;
        }
        header {
            background: #333;
            color: white;
            text-align: center;
            padding: 20px;
        }
        nav {
            background: #555;
            padding: 10px;
            text-align: center;
        }
        nav a {
            color: white;
            margin: 10px;
            text-decoration: none;
            font-weight: bold;
        }
        section {
            padding: 20px;
            margin: 10px;
            background: white;
            border-radius: 8px;
        }
        img {
            width: 150px;
            border-radius: 50%;
        }
        footer {
            text-align: center;
            padding: 10px;
            background: #333;
            color: white;
        }
        button {
            padding: 10px;
            background: #333;
            color: white;
            border: none;
            cursor: pointer;
        }
    </style>
</head>
<body>

<header>
    <h1>Your Name</h1>
    <p>Web Developer | Student</p>
    <img src="https://via.placeholder.com/150" alt="Profile Picture">
</header>

<nav>
    <a href="#about">About</a>
    <a href="#education">Education</a>
    <a href="#skills">Skills</a>
    <a href="#projects">Projects</a>
    <a href="#contact">Contact</a>
</nav>

<section id="about">
    <h2>About Me</h2>
    <p>I am a passionate student learning web development.</p>
</section>

<section id="education">
    <h2>Education</h2>
    <p>B.Tech in Computer Science</p>
</section>

<section id="skills">
    <h2>Skills</h2>
    <ul>
        <li>HTML</li>
        <li>CSS</li>
        <li>JavaScript</li>
    </ul>
</section>

<section id="projects">
    <h2>Projects</h2>
    <p>Portfolio Website, Blog Page, Image Gallery</p>
</section>

<section id="contact">
    <h2>Contact</h2>
    <form>
        <input type="text" placeholder="Your Name"><br><br>
        <input type="email" placeholder="Your Email"><br><br>
        <textarea placeholder="Your Message"></textarea><br><br>
        <button type="button" onclick="showMessage()">Send</button>
    </form>
</section>

<footer>
    <p>© 2026 My Portfolio</p>
</footer>

<script>
function showMessage() {
    alert("Message sent (demo only)");
}
</script>

</body>
</html>

